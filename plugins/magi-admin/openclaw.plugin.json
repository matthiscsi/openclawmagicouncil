{
  "id": "magi-admin",
  "name": "MAGI Admin",
  "description": "Allowlisted MAGI-only admin tools for gateway status, logs, and controlled restart.",
  "version": "0.1.0",
  "contracts": {
    "tools": [
      "magi_health_snapshot",
      "magi_gateway_restart",
      "magi_log_tail",
      "magi_discord_health",
      "magi_system_snapshot"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serviceName": {
        "type": "string"
      },
      "gatewayConfigPath": {
        "type": "string"
      },
      "logDir": {
        "type": "string"
      },
      "allowedRoots": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "logFiles": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "serviceName",
      "gatewayConfigPath",
      "logDir",
      "allowedRoots"
    ]
  }
}
