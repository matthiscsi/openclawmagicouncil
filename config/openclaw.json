{
  "env": {
    "shellEnv": {
      "enabled": true,
      "timeoutMs": 15000
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18790,
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18790",
        "http://localhost:18790",
        "http://192.168.129.169:18790",
        "http://100.100.237.73:18790",
        "https://homeserver.tailf7a295.ts.net:18790"
      ],
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "password",
      "allowTailscale": false,
      "password": {
        "source": "env",
        "provider": "default",
        "id": "OPENCLAW_GATEWAY_PASSWORD"
      }
    }
  },
  "discovery": {
    "mdns": {
      "mode": "off"
    },
    "wideArea": {
      "enabled": false
    }
  },
  "logging": {
    "level": "info",
    "file": "${MAGI_HOME}/logs/gateway.log",
    "consoleLevel": "info",
    "consoleStyle": "compact",
    "redactSensitive": "tools"
  },
  "commands": {
    "native": "auto",
    "text": true,
    "bash": true,
    "config": true,
    "debug": true,
    "restart": true
  },
  "messages": {
    "groupChat": {
      "historyLimit": 40
    }
  },
  "plugins": {
    "enabled": true,
    "allow": [
      "open-prose",
      "magi-admin",
      "openai",
      "memory-core"
    ],
    "entries": {
      "open-prose": {
        "enabled": true
      },
        "magi-admin": {
          "enabled": true,
          "config": {
            "serviceName": "openclaw-magi.service",
            "gatewayConfigPath": "${MAGI_HOME}/openclaw.json",
          "logDir": "${MAGI_HOME}/logs",
          "allowedRoots": [
            "${MAGI_HOME}"
          ],
          "logFiles": [
            "gateway.log",
            "bootstrap.log",
            "service-install.log"
          ]
        }
      },
      "openai": {
        "enabled": true
      }
    }
  },
  "tools": {
    "profile": "minimal",
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "melchior",
        "balthasar",
        "casper"
      ]
    },
    "elevated": {
      "enabled": true
    },
    "loopDetection": {
      "enabled": true,
      "historySize": 30,
      "warningThreshold": 8,
      "criticalThreshold": 14,
      "globalCircuitBreakerThreshold": 20,
      "detectors": {
        "genericRepeat": true,
        "knownPollNoProgress": true,
        "pingPong": true
      }
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "userTimezone": "Europe/Brussels",
      "timeFormat": "24",
      "models": {
        "openai-codex/gpt-5.4": {
          "alias": "magi-codex",
          "params": {
            "reasoning": {
              "effort": "low"
            }
          }
        }
      },
      "model": {
        "primary": "openai-codex/gpt-5.4"
      },
      "thinkingDefault": "low",
      "verboseDefault": "off",
      "timeoutSeconds": 240,
      "contextTokens": 120000,
      "heartbeat": {
        "every": "0m"
      },
      "maxConcurrent": 4,
      "subagents": {
        "thinking": "low",
        "maxConcurrent": 3,
        "runTimeoutSeconds": 300,
        "archiveAfterMinutes": 30
      },
      "sandbox": {
        "mode": "all",
        "backend": "docker",
        "scope": "agent",
        "workspaceAccess": "none",
        "workspaceRoot": "${MAGI_HOME}/sandboxes",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "containerPrefix": "openclaw-magi-",
          "workdir": "/workspace",
          "readOnlyRoot": false,
          "tmpfs": [
            "/tmp",
            "/var/tmp",
            "/run"
          ],
          "network": "bridge",
          "user": "1000:1000",
          "capDrop": [
            "ALL"
          ],
          "memory": "2g",
          "memorySwap": "4g",
          "cpus": 2
        }
      }
    },
    "list": [
      {
        "id": "magi",
        "default": true,
        "name": "MAGI",
        "workspace": "${MAGI_HOME}/workspaces/magi",
        "agentDir": "${MAGI_HOME}/agents/magi/agent",
        "model": {
          "primary": "openai-codex/gpt-5.4"
        },
        "thinkingDefault": "low",
        "groupChat": {
          "mentionPatterns": [
            "@magi",
            "magi"
          ]
        },
        "subagents": {
          "allowAgents": [
            "melchior",
            "balthasar",
            "casper"
          ],
          "requireAgentId": true
        },
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "alsoAllow": [
            "read",
            "write",
            "edit",
            "apply_patch",
            "exec",
            "process",
            "web_search",
            "web_fetch",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "sessions_spawn",
            "session_status",
            "magi-admin"
          ]
        }
      },
      {
        "id": "melchior",
        "name": "Melchior",
        "workspace": "${MAGI_HOME}/workspaces/melchior",
        "agentDir": "${MAGI_HOME}/agents/melchior/agent",
        "model": {
          "primary": "openai-codex/gpt-5.4"
        },
        "thinkingDefault": "low",
        "heartbeat": {
          "every": "0m"
        },
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "ro"
        },
        "tools": {
          "alsoAllow": [
            "read",
            "session_status",
            "web_search",
            "web_fetch"
          ]
        }
      },
      {
        "id": "balthasar",
        "name": "Balthasar",
        "workspace": "${MAGI_HOME}/workspaces/balthasar",
        "agentDir": "${MAGI_HOME}/agents/balthasar/agent",
        "model": {
          "primary": "openai-codex/gpt-5.4"
        },
        "thinkingDefault": "low",
        "heartbeat": {
          "every": "0m"
        },
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "ro"
        },
        "tools": {
          "alsoAllow": [
            "read",
            "session_status",
            "web_search",
            "web_fetch"
          ]
        }
      },
      {
        "id": "casper",
        "name": "Casper",
        "workspace": "${MAGI_HOME}/workspaces/casper",
        "agentDir": "${MAGI_HOME}/agents/casper/agent",
        "model": {
          "primary": "openai-codex/gpt-5.4"
        },
        "thinkingDefault": "low",
        "heartbeat": {
          "every": "0m"
        },
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "ro"
        },
        "tools": {
          "alsoAllow": [
            "read",
            "session_status",
            "web_search",
            "web_fetch"
          ]
        }
      }
    ]
  }
}
